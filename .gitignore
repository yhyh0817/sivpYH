/references/

# Only the paper-related scripts and modules are versioned in this repository.
/scripts/*
!/scripts/analyze_fusion_temporal_quality_split_robustness.py
!/scripts/compile_fusion_temporal_quality_baseline_table.py
!/scripts/download_vidllvip_subset.py
!/scripts/run_framewise_fusion_metric_baselines_independent.py
!/scripts/run_fusion_temporal_quality_external.py
!/scripts/run_fusion_temporal_quality_independent.py
!/scripts/run_fusion_temporal_quality_m3svd_full_test.py
