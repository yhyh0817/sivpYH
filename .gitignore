!/scripts/run_temcoco_searaft_flowd_independent.py
!/scripts/run_temcoco_searaft_flowd_m3svd_full_test.py
!/scripts/figures/
/scripts/figures/*
!/scripts/figures/generate_sivp_figures.py

/src/cursor_rgbt/*
!/src/cursor_rgbt/__init__.py
!/src/cursor_rgbt/fusion_temporal_quality.py
!/src/cursor_rgbt/temcoco_baselines.py
!/src/cursor_rgbt/temporal_sync.py

/tests/*
!/tests/test_fusion_temporal_quality.py
!/tests/test_temporal_sync.py

# Results are ignored by default; the verified manuscript artifacts are added
# explicitly to the repository.
/results/

